{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://argus.local/schemas/contracts/c6.compute-adapter.schema.json",
  "title": "C6 Compute Adapter Tool Interface",
  "description": "Descriptor and result contracts for units-tagged, uncertainty-tagged physics compute adapters.",
  "x-argus-contract": {
    "id": "C6",
    "owner": "S7",
    "version": "2.3.0"
  },
  "oneOf": [
    { "$ref": "#/$defs/AdapterDescriptor" },
    { "$ref": "#/$defs/EvalRequest" },
    { "$ref": "#/$defs/EvalResult" },
    { "$ref": "#/$defs/GradRequest" },
    { "$ref": "#/$defs/GradResult" },
    { "$ref": "#/$defs/BatchRequest" },
    { "$ref": "#/$defs/BatchResult" }
  ],
  "$defs": {
    "ArtifactRef": {
      "type": "string",
      "pattern": "^c4://[A-Za-z0-9._:/-]+$"
    },
    "Quantity": {
      "type": "object",
      "required": ["value", "units"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["number", "array"] },
        "units": { "type": "string", "minLength": 1 },
        "uncertainty": { "type": "object" }
      }
    },
    "OutputQuantity": {
      "type": "object",
      "required": ["value", "units", "uncertainty"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["number", "array"] },
        "units": { "type": "string", "minLength": 1 },
        "uncertainty": { "type": "object" }
      }
    },
    "JacobianEntry": {
      "type": "object",
      "required": ["value", "units", "output_units", "input_units"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number" },
        "units": { "type": "string", "minLength": 1 },
        "output_units": { "type": "string", "minLength": 1 },
        "input_units": { "type": "string", "minLength": 1 }
      }
    },
    "AdapterError": {
      "type": "object",
      "required": ["category", "message"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "UNITS_MISMATCH",
            "OUT_OF_DOMAIN",
            "PROVENANCE_UNAVAILABLE",
            "BUDGET",
            "ADAPTER_ERROR",
            "NOT_DIFFERENTIABLE",
            "BACKEND_UNAVAILABLE",
            "VERSION_UNSUPPORTED",
            "PERMISSION_DENIED"
          ]
        },
        "message": { "type": "string" },
        "diagnostics": { "type": "object" }
      }
    },
    "BudgetToken": {
      "type": "object",
      "required": ["token_ref", "remaining_units", "unit_cost"],
      "additionalProperties": false,
      "properties": {
        "token_ref": { "type": "string", "minLength": 1 },
        "remaining_units": { "type": "number", "minimum": 0 },
        "unit_cost": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "BatchBudgetState": {
      "type": "object",
      "required": ["token_ref", "limit_units", "unit_cost", "spent_units", "remaining_units"],
      "additionalProperties": false,
      "properties": {
        "token_ref": { "type": "string", "minLength": 1 },
        "limit_units": { "type": "number", "minimum": 0 },
        "unit_cost": { "type": "number", "exclusiveMinimum": 0 },
        "spent_units": { "type": "number", "minimum": 0 },
        "remaining_units": { "type": "number", "minimum": 0 },
        "halted_reason": { "type": "string", "enum": ["BUDGET"] },
        "halted_index": { "type": "integer", "minimum": 0 }
      }
    },
    "DomainDiagnostics": {
      "type": "object",
      "required": [
        "kind",
        "policy",
        "violated_fields",
        "distance",
        "validity_domain_guard_version",
        "validity_domain_guard_hash"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "policy": { "type": "string", "enum": ["flag", "refuse", "clamp_with_flag"] },
        "violated_fields": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "clamped_fields": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "distance": { "type": "number", "minimum": 0 },
        "fields": { "type": "object" },
        "validity_domain_guard_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-domain-1.0.0"
        },
        "validity_domain_guard_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$",
          "default": "blake3:353cb32c3b4d50a2f1a3626946cd23b7407b6a64240e405c32398e936f387bc5"
        }
      }
    },
    "SeedDerivation": {
      "type": "object",
      "required": [
        "algorithm",
        "seed_manager_version",
        "seed_manager_hash",
        "adapter_id",
        "seed_used",
        "seed_source"
      ],
      "additionalProperties": true,
      "properties": {
        "algorithm": { "type": "string", "enum": ["blake3-kdf-v1", "explicit", "unseeded"] },
        "seed_manager_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-seed-1.0.0"
        },
        "seed_manager_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$"
        },
        "adapter_id": { "type": "string", "minLength": 1 },
        "job_seed": { "type": "integer" },
        "dag_node_id": { "type": "string", "minLength": 1 },
        "call_index": { "type": "integer", "minimum": 0 },
        "derived_seed": { "type": "integer" },
        "seed_used": { "type": ["integer", "null"] },
        "seed_source": { "type": "string", "enum": ["derived", "explicit", "unseeded"] }
      }
    },
    "AdapterDescriptor": {
      "type": "object",
      "required": ["adapter_id", "version", "methods", "units_schema", "validity_domain", "determinism", "cost_class", "provenance_ref"],
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "methods": {
          "type": "array",
          "items": { "type": "string", "enum": ["describe", "evaluate", "grad", "batch_evaluate"] },
          "uniqueItems": true
        },
        "units_schema": { "type": "object" },
        "validity_domain": { "type": "object" },
        "determinism": { "type": "string", "enum": ["deterministic", "seeded", "stochastic"] },
        "differentiable": { "type": "boolean" },
        "cost_class": { "type": "string", "enum": ["toy", "standard", "heavy", "flagship_hpc_disallowed"] },
        "independence_tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "provenance_ref": { "$ref": "#/$defs/ArtifactRef" }
      }
    },
    "EvalRequest": {
      "type": "object",
      "required": ["adapter_id", "inputs"],
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "type": "string", "minLength": 1 },
        "c6_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "default": "2.3.0"
        },
        "caller_scopes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        },
        "inputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/Quantity" }
        },
        "seed": { "type": "integer" },
        "job_seed": { "type": "integer" },
        "dag_node_id": { "type": "string", "minLength": 1 },
        "call_index": { "type": "integer", "minimum": 0 },
        "budget_token_ref": { "type": "string" }
      }
    },
    "EvalResult": {
      "type": "object",
      "required": [
        "adapter_id",
        "outputs",
        "in_validity_domain",
        "extrapolation_flag",
        "provenance_ref",
        "seed_used",
        "seed_source",
        "seed_derivation",
        "unit_registry_version",
        "unit_registry_hash",
        "uncertainty_engine_version",
        "uncertainty_engine_hash",
        "validity_domain_guard_version",
        "validity_domain_guard_hash",
        "seed_manager_version",
        "seed_manager_hash",
        "domain_diagnostics"
      ],
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "type": "string", "minLength": 1 },
        "outputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/OutputQuantity" }
        },
        "in_validity_domain": { "type": "boolean" },
        "extrapolation_flag": { "type": "boolean" },
        "seed_used": { "type": ["integer", "null"] },
        "seed_source": { "type": "string", "enum": ["derived", "explicit", "unseeded"] },
        "seed_derivation": { "$ref": "#/$defs/SeedDerivation" },
        "domain_diagnostics": {
          "$ref": "#/$defs/DomainDiagnostics",
          "default": {
            "kind": "box",
            "policy": "flag",
            "violated_fields": [],
            "clamped_fields": [],
            "distance": 0,
            "fields": {},
            "validity_domain_guard_version": "argus-domain-1.0.0",
            "validity_domain_guard_hash": "blake3:353cb32c3b4d50a2f1a3626946cd23b7407b6a64240e405c32398e936f387bc5"
          }
        },
        "provenance_ref": { "$ref": "#/$defs/ArtifactRef" },
        "unit_registry_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-units-1.0.0"
        },
        "unit_registry_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$",
          "default": "blake3:d051549f426fb54fa67a0ef96611db2aebd0158c6b541e964c380d6cc58e06e5"
        },
        "uncertainty_engine_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-uncertainty-1.0.0"
        },
        "uncertainty_engine_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$",
          "default": "blake3:04c6c2c24fb730865ec58cc636250e709f73d54f27ac809afefe7fad360aff58"
        },
        "validity_domain_guard_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-domain-1.0.0"
        },
        "validity_domain_guard_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$",
          "default": "blake3:353cb32c3b4d50a2f1a3626946cd23b7407b6a64240e405c32398e936f387bc5"
        },
        "seed_manager_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-seed-1.0.0"
        },
        "seed_manager_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$"
        },
        "backend_name": {
          "type": "string",
          "enum": ["native_python", "jax", "pytorch", "subprocess_binary", "emulator_gp", "emulator_nn", "surrogate_diff"]
        },
        "backend_version": { "type": "string", "minLength": 1 },
        "backend_hash": { "type": "string", "pattern": "^blake3:[0-9a-f]{64}$" },
        "underlying_code_version": { "type": "string", "minLength": 1 },
        "error": {
          "$ref": "#/$defs/AdapterError"
        }
      }
    },
    "BatchRequest": {
      "type": "object",
      "required": ["method", "items", "budget_token"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "const": "batch_evaluate" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/EvalRequest" }
        },
        "budget_token": { "$ref": "#/$defs/BudgetToken" }
      }
    },
    "BatchItemResult": {
      "type": "object",
      "required": ["index"],
      "additionalProperties": false,
      "oneOf": [
        { "required": ["result"], "not": { "required": ["error"] } },
        { "required": ["error"], "not": { "required": ["result"] } }
      ],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "result": { "$ref": "#/$defs/EvalResult" },
        "error": { "$ref": "#/$defs/AdapterError" }
      }
    },
    "BatchResult": {
      "type": "object",
      "required": ["method", "items", "n_ok", "halted", "budget"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "const": "batch_evaluate" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/BatchItemResult" }
        },
        "n_ok": { "type": "integer", "minimum": 0 },
        "halted": { "type": "boolean" },
        "halted_index": { "type": ["integer", "null"], "minimum": 0 },
        "budget": { "$ref": "#/$defs/BatchBudgetState" },
        "partial_provenance_ref": { "$ref": "#/$defs/ArtifactRef" }
      }
    },
    "GradRequest": {
      "type": "object",
      "required": ["method", "adapter_id", "inputs"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "const": "grad" },
        "adapter_id": { "type": "string", "minLength": 1 },
        "c6_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "default": "2.3.0"
        },
        "caller_scopes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        },
        "inputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/Quantity" }
        },
        "seed": { "type": "integer" },
        "job_seed": { "type": "integer" },
        "dag_node_id": { "type": "string", "minLength": 1 },
        "call_index": { "type": "integer", "minimum": 0 },
        "budget_token_ref": { "type": "string" }
      }
    },
    "GradResult": {
      "type": "object",
      "required": [
        "adapter_id",
        "jacobian",
        "in_validity_domain",
        "extrapolation_flag",
        "provenance_ref",
        "seed_used",
        "seed_source",
        "seed_derivation",
        "unit_registry_version",
        "unit_registry_hash",
        "validity_domain_guard_version",
        "validity_domain_guard_hash",
        "seed_manager_version",
        "seed_manager_hash",
        "domain_diagnostics",
        "backend_name",
        "backend_version",
        "backend_hash",
        "underlying_code_version"
      ],
      "additionalProperties": false,
      "properties": {
        "adapter_id": { "type": "string", "minLength": 1 },
        "jacobian": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/JacobianEntry" }
          }
        },
        "in_validity_domain": { "type": "boolean" },
        "extrapolation_flag": { "type": "boolean" },
        "seed_used": { "type": ["integer", "null"] },
        "seed_source": { "type": "string", "enum": ["derived", "explicit", "unseeded"] },
        "seed_derivation": { "$ref": "#/$defs/SeedDerivation" },
        "domain_diagnostics": {
          "$ref": "#/$defs/DomainDiagnostics",
          "default": {
            "kind": "box",
            "policy": "flag",
            "violated_fields": [],
            "clamped_fields": [],
            "distance": 0,
            "fields": {},
            "validity_domain_guard_version": "argus-domain-1.0.0",
            "validity_domain_guard_hash": "blake3:353cb32c3b4d50a2f1a3626946cd23b7407b6a64240e405c32398e936f387bc5"
          }
        },
        "backend_name": {
          "type": "string",
          "enum": ["native_python", "jax", "pytorch", "subprocess_binary", "emulator_gp", "emulator_nn", "surrogate_diff"]
        },
        "backend_version": { "type": "string", "minLength": 1 },
        "backend_hash": { "type": "string", "pattern": "^blake3:[0-9a-f]{64}$" },
        "underlying_code_version": { "type": "string", "minLength": 1 },
        "provenance_ref": { "$ref": "#/$defs/ArtifactRef" },
        "unit_registry_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-units-1.0.0"
        },
        "unit_registry_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$",
          "default": "blake3:d051549f426fb54fa67a0ef96611db2aebd0158c6b541e964c380d6cc58e06e5"
        },
        "validity_domain_guard_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-domain-1.0.0"
        },
        "validity_domain_guard_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$",
          "default": "blake3:353cb32c3b4d50a2f1a3626946cd23b7407b6a64240e405c32398e936f387bc5"
        },
        "seed_manager_version": {
          "type": "string",
          "minLength": 1,
          "default": "argus-seed-1.0.0"
        },
        "seed_manager_hash": {
          "type": "string",
          "pattern": "^blake3:[0-9a-f]{64}$"
        }
      }
    }
  }
}
